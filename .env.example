# 複製成 .env 後填入。.env 已被 .gitignore 排除,切勿提交。
MATRIX_HOMESERVER=https://ims.opscloud.info

# 完整 user id 或 localpart。
MATRIX_USER_ID=@patrick.zyx:ims.opscloud.info

# 帳號密碼:用於每次啟動的新裝置登入(與 recovery key 同等機密,僅放此檔)。
MATRIX_PASSWORD=

# Secure Backup 還原金鑰:用來建立裝置信任 + 還原 key backup(機密)。
MATRIX_RECOVERY_KEY=

# 要監聽的房間 ID,逗號分隔,支援複數。
# (非必填)監聽清單已改由 dashboard 管理並存於 storage/rooms-config.json,可編輯 + 熱載入。
# 此處僅在 rooms-config.json 尚未建立時作為初始值/後備;首次到 dashboard「🏠 監聽房間」存檔後即以該檔為準。
MATRIX_ROOM_IDS=!jOuxmbWVxsEbbcByqa:ims.opscloud.info

# 新裝置顯示名稱(舊的同名裝置會在登入時自動清除)。
MATRIX_DEVICE_NAME=element-bot

# 觸發功能可選設定(有預設值,通常不用填)
# 註:LLM 語意判斷(use_llm:true 的規則)改用 Codex CLI(headless),吃登入帳號 quota,不需 API key。
# Codex 執行檔名稱或絕對路徑(預設 codex)
# CODEX_COMMAND=codex
# JUDGE_TIMEOUT_MS=120000
# AI_TIMEOUT_MS=1800000
# RULES_PATH=config/rules.json
# QUEUE_DIR=queue
# POLL_INTERVAL_MS=2000
# 崩潰重試保險:同一任務被回收重跑的最大嘗試次數,超過即送 failed/ 待人工(預設 3)
# MAX_TASK_ATTEMPTS=3

# 監控儀表板埠
DASHBOARD_PORT=3000

# 監控儀表板綁定位址(預設僅本機 127.0.0.1)。
# 要讓其他同事電腦跨機器連線,改成 0.0.0.0 或本機的區網 IP。
# 注意:目前 dashboard 的 /api/* 完全沒有身份驗證,一旦綁到區網位址,
# 同一網段內任何人都能看訊息、改規則、觸發任務——先確認網路環境可信再開放。
# DASHBOARD_HOST=0.0.0.0
